PORT=3001
NODE_ENV=development
LENSFLOW_STORE_FILE=./data/store.json
LENSFLOW_UPLOAD_DIR=./uploads
DATABASE_URL=file:./lensflow.db
SHOPIFY_APP_URL=https://bogdaapps-dnz0.onrender.com

# Shopify values are only needed when you wire the app back to a real Shopify store.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders,write_orders,read_customers,write_customers
