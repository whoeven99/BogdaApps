{{ 'lens-widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'lens-widget.js' | asset_url }}" defer></script>

<div
  class="lens-widget"
  data-lens-widget
  data-widget-mode="{{ block.settings.widget_mode }}"
  data-product-id="{{ product.id }}"
  data-selected-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-proxy-path="{{ routes.root }}apps/product-match"
  data-record-path="{{ routes.root }}apps/purchase-records"
  {{ block.shopify_attributes }}
>
  <div class="lens-widget__header">
    <h3 class="lens-widget__title">{{ block.settings.heading }}</h3>
    <div class="lens-widget__subtitle">{{ block.settings.subtitle }}</div>
  </div>

  <form class="lens-widget__form" data-lens-widget-form>
    <div class="lens-widget__field-grid" data-lens-widget-dynamic-fields>
      <div class="lens-widget__loading">{{ 'lens_widget.loading' | t }}</div>
    </div>

    <div class="lens-widget__actions">
      <button type="submit" class="lens-widget__submit">
        {{ 'lens_widget.submit' | t }}
      </button>
    </div>
  </form>

  <div data-lens-widget-output>
    <div class="lens-widget__empty">
      {{ 'lens_widget.empty' | t }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Prescription Recommender",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "widget_mode",
      "label": "Widget mode",
      "default": "live",
      "options": [
        { "value": "live", "label": "Live data mode" },
        { "value": "prototype", "label": "Prototype mode" }
      ]
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "输入验光结果，找到适合的眼镜" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "表单字段来自商家后台配置，消费者提交后会自动匹配对应库存货品。" }
  ]
}
{% endschema %}
