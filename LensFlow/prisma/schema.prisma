// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model LensRule {
  id         String              @id @default(cuid())
  shop       String
  productId  String
  name       String
  priority   Int
  enabled    Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  conditions LensRuleCondition[]
  actions    LensRuleAction[]
}

model LensRuleCondition {
  id       String   @id @default(cuid())
  ruleId   String
  field    String
  operator String
  value    String
  rule     LensRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

model LensRuleAction {
  id           String   @id @default(cuid())
  ruleId       String
  type         String
  lensOptionId String
  message      String?
  variantId    String?
  rule         LensRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

model ParameterUnit {
  id         String                @id @default(cuid())
  shop       String
  code       String
  label      String
  precision  Int                   @default(0)
  step       Float?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  parameters ParameterDefinition[]

  @@unique([shop, code])
}

model ParameterTemplate {
  id              String                   @id @default(cuid())
  shop            String
  name            String
  productCategory String
  description     String?
  active          Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  parameters      ParameterDefinition[]
  productConfigs  ProductParameterConfig[]

  @@unique([shop, name])
}

model ParameterDefinition {
  id             String            @id @default(cuid())
  templateId     String
  code           String
  label          String
  type           String
  required       Boolean           @default(false)
  position       Int               @default(0)
  unitId         String?
  configJson     String?
  template       ParameterTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  unit           ParameterUnit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@unique([templateId, code])
}

model ProductParameterConfig {
  id                      String                  @id @default(cuid())
  shop                    String
  shopifyProductId        String
  templateId              String
  productType             String?
  allowOneTimePurchase    Boolean                 @default(true)
  allowSubscription       Boolean                 @default(false)
  parameterOverridesJson  String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  template                ParameterTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  valueMappings           ParameterValueMapping[]

  @@unique([shop, shopifyProductId])
}

model ParameterValueMapping {
  id               String                 @id @default(cuid())
  productConfigId  String
  signature        String
  shopifyVariantId String
  inventoryPolicy  String?
  priceAdjustment  Float?
  metadataJson     String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  productConfig    ProductParameterConfig @relation(fields: [productConfigId], references: [id], onDelete: Cascade)

  @@unique([productConfigId, signature])
}

model PurchaseRecord {
  id                    String   @id @default(cuid())
  shop                  String
  source                String   @default("theme_widget")
  status                String   @default("cart_added")
  purchaseMode          String
  shopifyProductId      String
  productTitle          String?
  shopifyVariantId      String
  variantTitle          String?
  parameterTemplateName String?
  signature             String?
  parameterValuesJson   String
  subscriptionPlanId    String?
  subscriptionPlanName  String?
  sellingPlanId         String?
  priceAdjustment       Float?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([shop, createdAt])
  @@index([shop, shopifyProductId, createdAt])
  @@index([shop, status, createdAt])
}

model NotificationLog {
  id          String   @id @default(cuid())
  shop        String
  channel     String
  provider    String
  category    String
  recipient   String
  subject     String
  status      String
  error       String?
  payloadJson String?
  createdAt   DateTime @default(now())

  @@index([shop, createdAt])
  @@index([shop, category, createdAt])
  @@index([shop, status, createdAt])
}
