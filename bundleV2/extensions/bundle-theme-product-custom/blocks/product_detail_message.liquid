<div
  id="ciwi-product-message-root"
  class="ciwi-product-message-src"
  data-ciwi-heading="{{ block.settings.heading | escape }}"
  data-ciwi-message="{{ block.settings.message | escape }}"
  data-ciwi-selectors="{{ block.settings.anchor_selector | escape }}"
></div>

{% schema %}
{
  "name": "Product detail message",
  "target": "body",
  "enabled_on": {
    "templates": ["product"]
  },
  "stylesheet": "product-detail-message.css",
  "javascript": "product-detail-message.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "标题（可选）",
      "default": "-"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "自定义文案",
      "default": "在这里111填写要在产品信息下方显示的内容。"
    },
    {
      "type": "text",
      "id": "anchor_selector",
      "label": "锚点选择器（可选）",
      "info": "逗号分隔多个 CSS 选择器，命中第一个后在其后插入内容。留空则使用 Dawn 等常见主题默认选择器。",
      "default": "-"
    }
  ]
}
{% endschema %}
