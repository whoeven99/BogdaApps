<div
  id="ciwi-product-message-root"
  class="ciwi-product-message-src"
></div>

<script id="ciwi-bundles-config" type="application/json">
  {
    "shopifyDomain": "{{ shop.domain }}",
    "moneyFormat": "{{ shop.money_format | escape }}",
    "productId": {{ product.id | default: "null" }},
    "variantIds": [
      {% for item in product.variants %}
        {{ item.id }}{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    "marketId": {{ localization.market.id | default: "null" }},
    "variants": [
      {% for item in product.variants %}
        {
          "id": "{{ item.id }}",
          "available": {% if item.available %}true{% else %}false{% endif %},
          "compareAtPrice": {{ item.compare_at_price | json }},
          "price": {{ item.price | json }},
          "inventoryQuantity": {{ item.inventory_quantity | default: 0 }},
          "inventoryPolicy": {{ item.inventory_policy | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    "firstVariant": {
      "compareAtPrice": {{ product.variants[0].compare_at_price | json }},
      "price": {{ product.variants[0].price | json }}
    },
    "currencySymbol": "{{ localization.country.currency.symbol | escape }}"
  }
</script>

{% if shop.metafields.ciwi_bundle %}
  {% if shop.metafields.ciwi_bundle["ciwi-bundle-enabled-prod"] %}
    <script id="ciwi-bundle-enabled-prod" type="application/json">
      {{ shop.metafields.ciwi_bundle["ciwi-bundle-enabled-prod"].value }}
    </script>
  {% endif %}

  {% if shop.metafields.ciwi_bundle["ciwi-bundle-enabled-test"] %}
    <script id="ciwi-bundle-enabled-test" type="application/json">
      {{ shop.metafields.ciwi_bundle["ciwi-bundle-enabled-test"].value }}
    </script>
  {% endif %}

  {% if shop.metafields.ciwi_bundle["ciwi-bundle-offers-active-env"] %}
    <script id="ciwi-bundle-offers-active-env" type="application/json">
      {{ shop.metafields.ciwi_bundle["ciwi-bundle-offers-active-env"].value }}
    </script>
  {% endif %}

  {% if shop.metafields.ciwi_bundle["ciwi-bundle-offers-prod"] %}
    <script id="ciwi-bundle-offers-prod" type="application/json">
      {{ shop.metafields.ciwi_bundle["ciwi-bundle-offers-prod"].value }}
    </script>
  {% endif %}

  {% if shop.metafields.ciwi_bundle["ciwi-bundle-offers-test"] %}
    <script id="ciwi-bundle-offers-test" type="application/json">
      {{ shop.metafields.ciwi_bundle["ciwi-bundle-offers-test"].value }}
    </script>
  {% endif %}

  {% if shop.metafields.ciwi_bundle["ciwi-bundle-offers"] %}
    <script id="ciwi-bundle-offers" type="application/json">
      {{ shop.metafields.ciwi_bundle["ciwi-bundle-offers"].value }}
    </script>
  {% endif %}
{% endif %}

<script src="{{ 'product-detail-message.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Ciwi Bundle & Discount",
  "target": "body",
  "enabled_on": {
    "templates": ["product"]
  },
  "stylesheet": "product-detail-message.css"
}
{% endschema %}
