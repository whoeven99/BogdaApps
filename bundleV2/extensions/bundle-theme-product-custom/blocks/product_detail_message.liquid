<div
  id="ciwi-product-message-root"
  class="ciwi-product-message-src"
></div>

<script id="ciwi-bundles-config" type="application/json">
  {
    "shopifyDomain": "{{ shop.domain }}",
    "moneyFormat": "{{ shop.money_format | escape }}",
    "productId": {{ product.id | default: "null" }},
    "variantIds": [
      {% for item in product.variants %}
        {{ item.id }}{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    "hasSubscription": {% if product.selling_plan_groups and product.selling_plan_groups.size > 0 %}true{% else %}false{% endif %},
    "sellingPlanGroups": [
      {% for group in product.selling_plan_groups %}
        {
          "id": {{ group.id | json }},
          "name": {{ group.name | json }},
          "sellingPlans": [
            {% for selling_plan in group.selling_plans %}
              {
                "id": {{ selling_plan.id | json }},
                "name": {{ selling_plan.name | json }}
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    "marketId": {{ localization.market.id | json }},
    "countryIsoCode": {{ localization.country.iso_code | json }},
    "variants": [
      {% for item in product.variants %}
        {
          "id": "{{ item.id }}",
          "available": {% if item.available %}true{% else %}false{% endif %},
          "compareAtPrice": {{ item.compare_at_price | json }},
          "price": {{ item.price | json }},
          "inventoryQuantity": {{ item.inventory_quantity | default: 0 }},
          "inventoryPolicy": {{ item.inventory_policy | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    "firstVariant": {
      "compareAtPrice": {{ product.variants[0].compare_at_price | json }},
      "price": {{ product.variants[0].price | json }}
    },
    "currencySymbol": "{{ localization.country.currency.symbol | escape }}"
  }
</script>

{% if shop.metafields.ciwi_bundle %}
  {% if shop.metafields.ciwi_bundle["ciwi-bundle-enabled"] %}
    <script id="ciwi-bundle-enabled" type="application/json">
      {{ shop.metafields.ciwi_bundle["ciwi-bundle-enabled"].value }}
    </script>
  {% endif %}

  {% comment %}
    旧版整包 ciwi-bundle-offers（已弃用）；新版为分片：ciwi-bundle-offer-ids + offer-{id}
  {% endcomment %}
  {% if shop.metafields.ciwi_bundle["ciwi-bundle-offers"] %}
    <script id="ciwi-bundle-offers" type="application/json">
      {{ shop.metafields.ciwi_bundle["ciwi-bundle-offers"].value }}
    </script>
  {% elsif shop.metafields.ciwi_bundle["ciwi-bundle-offer-ids"] %}
    <script id="ciwi-bundle-offer-ids" type="application/json">
      {{ shop.metafields.ciwi_bundle["ciwi-bundle-offer-ids"].value }}
    </script>
    {% if shop.metafields.ciwi_bundle["ciwi-bundle-offer-sync-at"] %}
      <script id="ciwi-bundle-offer-sync-at" type="application/json">
        {{ shop.metafields.ciwi_bundle["ciwi-bundle-offer-sync-at"].value | json }}
      </script>
    {% endif %}
    {% if shop.metafields.ciwi_bundle["ciwi-bundle-offer-count"] %}
      <script id="ciwi-bundle-offer-count" type="application/json">
        {{ shop.metafields.ciwi_bundle["ciwi-bundle-offer-count"].value | json }}
      </script>
    {% endif %}
    {% assign _ciwi_offer_ids = shop.metafields.ciwi_bundle["ciwi-bundle-offer-ids"].value %}
    {% if _ciwi_offer_ids %}
      {% for _ciwi_oid in _ciwi_offer_ids %}
        {% assign _ciwi_shard_key = "offer-" | append: _ciwi_oid %}
        {% if shop.metafields.ciwi_bundle[_ciwi_shard_key] %}
          <script type="application/json" data-ciwi-bundle-offer-shard="{{ _ciwi_oid | escape }}">
            {{ shop.metafields.ciwi_bundle[_ciwi_shard_key].value }}
          </script>
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endif %}
{% endif %}

<script src="{{ 'product-detail-message.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Ciwi Bundle & Discount",
  "target": "body",
  "enabled_on": {
    "templates": ["product"]
  },
  "stylesheet": "product-detail-message.css"
}
{% endschema %}
