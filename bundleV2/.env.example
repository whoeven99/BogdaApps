# 复制为 .env 并填写真实值（.env 已被 git 忽略）
# 运行时数据源选择：local=本地 sqlite；test=远端 turso
ENV="local"
#
# Prisma CLI（migrate / 本地 SQLite）使用 —— 连 Turso 时应用仍建议保留 file: 以便 migrate
DATABASE_URL="file:./prisma/dev.sqlite"

# 可选：应用运行时连 Turso（与上面的 file: 并存）
# TURSO_DATABASE_URL="libsql://YOUR_DB.aws-REGION.turso.io"
# TURSO_AUTH_TOKEN="eyJ..."

# 若不用 Turso、且整个环境都用本地文件库，只保留 DATABASE_URL=file:... 即可

# Shopify（dev 时 CLI 常会自动提供；自建进程时需要）
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SCOPES=write_metaobject_definitions,write_metaobjects,write_products,write_discounts,write_metafields,read_metafields,read_products
# SHOPIFY_APP_URL=https://your-tunnel-or-host
# SHOP_CUSTOM_DOMAIN=
