# 复制为 .env 并填写真实值（.env 已被 git 忽略）
ENV="local"
#
# Prisma CLI（migrate / 本地 SQLite）使用 —— 连 Turso 时应用仍建议保留 file: 以便 migrate
DATABASE_URL="file:./prisma/dev.sqlite"

# 应用运行时选库（勿用 NODE_ENV 推断业务环境；db.server 只看本项与 NODE_ENV）
# - local | sqlite：Prisma 直连 DATABASE_URL（本地文件）
# - turso | test：Prisma + LibSQL 连 Turso（须同时设 TURSO_*）
# 未设置时：NODE_ENV 为 production | prod | test 会默认走 Turso，否则走 local。
# 因此「NODE_ENV=production 但未配 Turso」会报错 —— 要么配齐 TURSO_*，要么取消下一行注释：
# DATABASE_TARGET=local

# Turso（仅当 DATABASE_TARGET=turso|test，或未设且 NODE_ENV=production|test 时需要）
# TURSO_DATABASE_URL="libsql://YOUR_DB.aws-REGION.turso.io"
# TURSO_AUTH_TOKEN="eyJ..."

# Render MCP（.cursor/mcp.json 使用 ${env:RENDER_API_KEY}；需写入本文件并同步到系统用户环境变量，或从已加载 .env 的终端启动 Cursor）
# RENDER_API_KEY=rnd_...

# Shopify（dev 时 CLI 常会自动提供；自建进程时需要）
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SCOPES=write_metaobject_definitions,write_metaobjects,write_products,write_discounts,read_products
# SHOPIFY_APP_URL=https://your-tunnel-or-host
# SHOP_CUSTOM_DOMAIN=
